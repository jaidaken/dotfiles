;label-occupied-foreground = #1B2443
;label-urgent = %icon%
;label-urgent-foreground = #31ABDE
;label-empty = %icon%
;label-empty-foreground = #FFFFFF

[module/date]
type = internal/date
label-background = ${colors.background}
label = %date% - %time%
label-padding = 2
date = %a %d
time = %H:%M:%S
interval = 1

[module/customvol]
type = custom/script
exec = ~/.config/i3/scripts/customvol 5 pulse
label = "     %output%   "
tail = true
interval = 0

[module/volume]
type = internal/volume

volume-foreground = #222

format-volume = <ramp-volume> <label-volume>
module-margin-right = 1
ramp-volume-0 =  
ramp-volume-1 =  
ramp-volume-2 = 

label-muted = 🔇muted

[module/battery]
type = internal/battery
battery = BAT0
adapter = ADP1
full-at = 97
interval = 30

format-charging = "<animation-charging> <label-charging>      "   
;format-charging-background = ${colors.accent}

format-discharging = "<ramp-capacity> <label-discharging>     "

format-full-prefix-foreground = ${colors.foreground}

ramp-capacity-0 = " "
ramp-capacity-1 = " "
ramp-capacity-2 = " "
ramp-capacity-3 = " "
ramp-capacity-4 = " "
;ramp-capacity-foreground = ${colors.accent}

animation-charging-0 = " "
animation-charging-1 = " "
animation-charging-2 = " "
;animation-charging-foreground = ${colors.foreground}
animation-charging-framerate = 750

[global/wm]
margin-top = 5
margin-bottom = 5
