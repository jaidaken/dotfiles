egrep -v '^#' .ncmpcpp/config
mpd_music_dir = "~/Music/"

#mpd_crossfade_time = "0"
mpd_host = "127.0.0.1"
mpd_port = "6600"

visualizer_fifo_path = "~/.config/mpd/mpd.fifo"
visualizer_output_name = "my_fifo"
visualizer_sync_interval = "30" 
visualizer_in_stereo = "no"
visualizer_type = "spectrum" (spectrum/wave)
visualizer_look = "▋▋"
visualizer_color = "33"


main_window_highlight_color = "118"

progressbar_look = "—▬—"
progressbar_color = "118"
progressbar_elapsed_color = "25"

song_list_format = " $5%a $2•  $8%t"
#song_list_format = "$1• $8%t $1by $2%a$2 $R$1%l"
#song_list_format = "$8 %t $R$8"
song_status_format = " $6%a  $7%t  $5%b "


#now_playing_prefix = "$b$8»$2»$4»$3» "
now_playing_prefix = "$b$2> "
now_playing_suffix = "$8$/b"

song_columns_list_format = "(8f)[23]{l}  (32)[105]{a} (42)[105]{t|f} (18)[70]{b}"
## song_columns_list_format = "(5)[]{} (22)[105]{a} (20)[105]{t|f} (49)[65]{b} (4)[173]{l}"

color1 = "118"
color2 = "33"

mouse_support = "yes"
header_visibility = "no"
statusbar_visibility = "yes"
playlist_display_mode = "classic" (classic/columns)
autocenter_mode = "yes"
titles_visibility = "no"
enable_window_title = "no"

